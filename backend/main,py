import os
import time
import asyncio
from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from typing import List, Dict, Any, Optional

# Import modules from the pipeline implementation
from pipeline import get_hybrid_retriever, generate_final_answer

app = FastAPI(title="Senior AI Financial Analyst API Server")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

class QueryRequest(BaseModel):
    query: str
    thread_id: Optional[str] = "default_session"

class ChatResponse(BaseModel):
    answer: str
    num_docs: int
    latency_seconds: float
    sources: List[str]

# Global/Shared BM25 placeholder for demo compatibility orchestration
# In true production, persist or fit this on startup vocabulary
class MockBM25:
    def encode_documents(self, texts): return [{"indices": [1], "values": [1.0]} for _ in texts]
    def encode_queries(self, texts): return {"indices": [1], "values": [1.0]}

bm25_instance = MockBM25()

@app.get("/health")
def health_check():
    return {"status": "healthy", "timestamp": time.time()}

@app.post("/analyze/stream", response_model=ChatResponse)
async def analyze_stream(request: QueryRequest):
    start_time = time.time()
    try:
        # 1. Fetch relevant hybrid context indices
        retriever = get_hybrid_retriever(bm25_instance)
        docs = retriever.invoke(request.query)
        
        # 2. Run analysis generation chain
        answer = generate_final_answer(request.query, docs)
        
        latency = time.time() - start_time
        sources_list = list(set([doc.metadata.get("source", "Unknown") for doc in docs]))
        
        return ChatResponse(
            answer=answer,
            num_docs=len(docs),
            latency_seconds=round(latency, 2),
            sources=sources_list
        )
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

if __name__ == "__main__":
    import uvicorn
    uvicorn.run("main:app", host="0.0.0.0", port=8000, reload=True)